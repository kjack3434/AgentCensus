# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/
build/
dist/
.eggs/

# Tooling
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# OS / macOS (incl. external-drive cruft)
.DS_Store
._*
.Spotlight-V100
.Trashes
.AppleDouble

# Secrets / local env (the tool reads AGENTCENSUS_* from the environment, never a file)
.env
.env.*

# Credentials / service-account keys — NEVER commit. The tool reads these by path
# (e.g. --gcp-key-file key.json), so guard the common filenames defensively.
*.pem
*.key
*.p12
*.pfx
key.json
*-key.json
*-sa.json
service-account*.json
client_secret*.json
credentials.json

# Node (only used locally to build the demo GIF)
node_modules/

# Generated reports — never commit a real tenant's discovery output
/reports/
report.html
*.report.html
out.json

# Internal / local-only (not part of the public repo)
/docs/
/memories/
/.githooks/

# AI assistant / editor artifacts — keep local, never commit (applies to contributors too)
CLAUDE.md
**/CLAUDE.md
AGENTS.md
GEMINI.md
**/GEMINI.md
.claude/
.cursor/
.cursorrules
.windsurf/
.windsurfrules
.aider*
.playwright-mcp/
.codex/
.gemini/
.continue/
.clinerules

# Editor settings
.vscode/
.idea/
*.swp
